{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev:server": "cross-env NODE_ENV=development NODE_OPTIONS=--dns-result-order=ipv4first tsx watch server/index.ts",
    "dev:client": "cross-env NODE_ENV=development vite",
    "dev:admin": "cross-env NODE_ENV=development ADMIN_PORT=5174 VITE_ADMIN_PORT=5174 npm run dev --prefix ./Admin",
    "dev:Admin": "npm run dev:admin",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:admin\"",
    "dev": "npm run dev:server",
    "prebuild": "node scripts/ensure-dev-deps.cjs",
    "build:client": "node scripts/run-vite-build.cjs",
    "build:admin": "node scripts/run-vite-build.cjs --cwd Admin",
    "build:admin:vercel": "node scripts/run-vite-build.cjs --cwd Admin --env ADMIN_BUILD_OUT_DIR=dist/client/admin --env VITE_ADMIN_BASE_PATH=/admin/",
    "build:server": "node scripts/run-esbuild.cjs server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:server:vercel": "node scripts/run-esbuild.cjs server/index.ts --platform=node --bundle --minify --format=esm --outdir=server-build --target=node20 --external:vite --node-esm-require-banner",
    "build:vercel": "node scripts/clean-vercel-artifacts.cjs && npm run build:client && npm run build:admin:vercel && npm run build:server:vercel && node scripts/prepare-vercel-media-assets.cjs && node scripts/clean-vercel-artifacts.cjs",
    "build": "npm run build:client && npm run build:admin && npm run build:server",
    "start": "node scripts/start-production.cjs",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "seo:audit": "node scripts/seo-governance-audit.cjs",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:logs": "pm2 logs mec-api",
    "pm2:save": "pm2 save",
    "vercel:domains:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-vercel-domains.ps1",
    "vercel:email:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-vercel-email.ps1",
    "sendgrid:dns:verify": "powershell -ExecutionPolicy Bypass -File scripts/verify-sendgrid-dns.ps1",
    "check": "tsc --pretty false",
    "db:push": "drizzle-kit push",
    "seed:partner-videos": "tsx -r dotenv/config server/seed-partner-videos.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "date-fns": "^3.6.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^4.22.2",
    "express-session": "^1.18.2",
    "framer-motion": "^11.13.1",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "input-otp": "^1.4.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.453.0",
    "memorystore": "^1.6.7",
    "multer": "^2.0.2",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "openai": "^5.8.2",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.2.5",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "ws": "^8.20.1",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.15",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.0",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "5.6.3",
    "vite": "^8.0.16"
  },
  "optionalDependencies": {
    "bufferutil": "4.1.0"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  }
}
