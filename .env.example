NODE_ENV=production
HOST=127.0.0.1
PORT=5000
ADMIN_PORT=5174

# Public service URLs
PUBLIC_APP_URL=https://mtendereeducationconsult.com
FRONTEND_URL=https://mtendereeducationconsult.com
ADMIN_APP_URL=https://admin.mtendereeducationconsult.com
API_APP_URL=https://api.mtendereeducationconsult.com
# Leave empty on Vercel so both public and admin clients call the same-origin /api routes.
VITE_API_URL=
VITE_SITE_URL=https://mtendereeducationconsult.com

# Backend CORS: production also allows VERCEL_URL automatically for preview deployments.
CORS_ORIGIN=https://mtendereeducationconsult.com,https://admin.mtendereeducationconsult.com
ALLOWED_ORIGINS=https://mtendereeducationconsult.com,https://admin.mtendereeducationconsult.com

# Required secrets. Generate unique production values before deployment.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
JWT_SECRET=replace-with-a-strong-random-secret
SEED_SUPER_ADMIN_EMAIL=admin@mtendereeducationconsult.com
SEED_SUPER_ADMIN_PASSWORD=replace-with-a-strong-one-time-seed-password

# Stable operational role accounts. Seed scripts preserve existing passwords by default.
# Set these only for first-time account creation or an explicit authorized rotation.
SEED_ROLE_ACCOUNT_DOMAIN=mtendereeducationconsult.com
SEED_SUPER_ADMIN_USERNAME=mec_super_admin
SEED_ADMIN_USERNAME=mec_admin
SEED_WRITER_USERNAME=mec_writer
SEED_VIEWER_USERNAME=mec_viewer
SEED_ADMIN_EMAIL=admin@mtendereeducationconsult.com
SEED_WRITER_EMAIL=writer@mtendereeducationconsult.com
SEED_VIEWER_EMAIL=viewer@mtendereeducationconsult.com
SEED_ADMIN_PASSWORD=replace-with-a-strong-admin-password
SEED_WRITER_PASSWORD=replace-with-a-strong-writer-password
SEED_VIEWER_PASSWORD=replace-with-a-strong-viewer-password

# Email delivery
# Production must use a verified sender domain. Resend's onboarding@resend.dev
# sender is only for smoke tests to the Resend account owner and is not
# production-ready for public recipients.
RESEND_DOMAIN=mtendereeducationconsult.com
EMAIL_FROM="Mtendere Education Consult <no-reply@mail.mtendereeducationconsult.com>"
EMAIL_PROVIDER_ORDER=sendgrid,ses,mailgun,resend,postmark,smtp,custom
EMAIL_QUEUE_WORKER_ENABLED=true
EMAIL_QUEUE_WORKER_INTERVAL_MS=15000
EMAIL_PROVIDER_INLINE_RETRIES=2
EMAIL_PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
EMAIL_PROVIDER_CIRCUIT_COOLDOWN_MS=120000
# In local/test, live provider delivery still requires EMAIL_ALLOW_LIVE_TEST_SENDS=true.
EMAIL_DRY_RUN=false
EMAIL_ALLOW_LIVE_TEST_SENDS=false
EMAIL_ACTIVATION_REQUIRES_DNS_READY=true
EMAIL_TRACKING_SECRET=replace-with-random-email-tracking-secret
EMAIL_LINK_BASE_URL=https://links.mtendereeducationconsult.com
EMAIL_WEBHOOK_SIGNING_SECRET=replace-with-random-webhook-secret
EMAIL_WEBHOOK_DEDUP_TTL_MS=86400000
METRICS_SECRET=replace-with-random-metrics-secret
E2E_TEST_SECRET=replace-with-random-e2e-secret-for-non-production-only
CRON_SECRET=replace-with-random-cron-secret
SENDGRID_TRACKING_ENABLED=true
RESEND_API_KEY=
SENDGRID_API_KEY=
# Optional SendGrid SMTP fallback. If SMTP_HOST is smtp.sendgrid.net and SMTP_USER is apikey,
# the app can use SMTP_PASSWORD as the SendGrid API key when SENDGRID_API_KEY is empty.
SMTP_HOST=smtp.sendgrid.net
SMTP_USER=apikey
SMTP_PASSWORD=
SMTP_PORT=587
POSTMARK_SERVER_TOKEN=
POSTMARK_MESSAGE_STREAM=outbound
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net
AWS_SES_REGION=
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_CONFIGURATION_SET=
# Legacy/custom provider fallback. Leave empty when using the enterprise providers above.
EMAIL_API_URL=
EMAIL_API_KEY=
ADMIN_NOTIFICATION_EMAIL=
ADMIN_NOTIFICATION_PHONE=

# Optional SMS / WhatsApp delivery providers.
# SMS_API_* and WHATSAPP_API_* are generic HTTP webhook fallbacks.
SMS_API_URL=
SMS_API_KEY=
SMS_API_FROM=
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_API_FROM=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
TWILIO_WHATSAPP_FROM=whatsapp:+0000000000
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
COMMUNICATION_DOCUMENT_LINK_TTL_DAYS=30
RECAPTCHA_SECRET_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=USD
REFERRAL_RELEASE_WORKER_ENABLED=false
REFERRAL_RELEASE_WORKER_MS=900000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=20
ADMIN_RATE_LIMIT_MAX=60

# Optional HMAC protection for high-risk admin API operations.
# Use for signed server-to-server/admin automation requests; browser clients should not receive this secret.
ADMIN_HMAC_SECRET=
ADMIN_HMAC_REQUIRED=false
ADMIN_HMAC_MAX_SKEW_MS=300000
MFA_ENCRYPTION_KEY=replace-with-random-32-byte-mfa-encryption-key
# Optional deployment-level override for the admin MFA policy.
# Leave empty to use the admin settings file.
ADMIN_TWO_FACTOR_REQUIRED=

# Optional integrations
OPENAI_API_KEY=
REDIS_URL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Search, analytics, and webmaster verification
VITE_GA4_MEASUREMENT_ID=
GA4_MEASUREMENT_ID=
VITE_GOOGLE_SITE_VERIFICATION=
GOOGLE_SITE_VERIFICATION=
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://mtendereeducationconsult.com
VITE_BING_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
BING_WEBMASTER_SITE_URL=https://mtendereeducationconsult.com
VITE_YANDEX_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=
VITE_BAIDU_SITE_VERIFICATION=
BAIDU_SITE_VERIFICATION=
SITE_LAST_REVIEWED_AT=2026-06-04T00:00:00.000Z
VITE_SITE_LAST_REVIEWED_AT=2026-06-04T00:00:00.000Z
