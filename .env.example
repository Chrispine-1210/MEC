# Copy this file to `.env` for local development.
# Do not commit real credentials.

# Runtime
NODE_ENV=development
PORT=5000

# Security
JWT_SECRET=replace-with-a-long-random-secret

# API and CORS
VITE_API_URL=http://localhost:5000
VITE_SITE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mec?sslmode=disable
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/mec?sslmode=disable

# Redis (optional, falls back to memory cache when omitted)
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Observability
METRICS_PATH=/metrics
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# MFA policy
MFA_REQUIRED_ROLES=admin,super_admin
MFA_ENCRYPTION_KEY=replace-with-strong-32-byte-secret
SKIP_DB_SCHEMA_BOOTSTRAP=0

# Integrations
OPENAI_API_KEY=sk-your-openai-key
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Email/SMS providers (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
