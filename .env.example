NODE_ENV=development
PORT=5000

# Public URLs
PUBLIC_APP_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5000
ADMIN_APP_URL=http://localhost:5174
CORS_ORIGIN=http://localhost:5000,http://localhost:5173,http://localhost:5174

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host:5432/database?sslmode=require

# Email delivery
EMAIL_FROM="Mtendere Education Consult <mtendereeducation@gmail.com>"
EMAIL_API_URL=
EMAIL_API_KEY=
ADMIN_NOTIFICATION_EMAIL=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_CURRENCY=USD
REFERRAL_RELEASE_WORKER_ENABLED=false
REFERRAL_RELEASE_WORKER_MS=900000

# Optional rate limits
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
